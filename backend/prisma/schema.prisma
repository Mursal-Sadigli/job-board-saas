generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  EMPLOYER
  CANDIDATE
  ADMIN
}

model User {
  id            String    @id @default(uuid())
  clerkId       String    @unique
  email         String    @unique
  name          String?
  firstName     String?
  lastName      String?
  role          UserRole  @default(CANDIDATE)
  companyName   String?
  logoUrl       String?
  title         String?
  bio           String?
  location      String?
  phone         String?
  skills        String[]  @default([])
  experience    Json?     @default("[]")
  education     Json?     @default("[]")
  socialLinks   Json?     @default("[]")
  notificationSettings Json? @default("{\"dailyDigest\":true,\"newApplications\":true,\"candidateMessages\":true,\"jobExpiry\":true,\"platformUpdates\":false,\"pushNotifications\":false,\"minRating\":\"any\"}")
  cvUploadCount Int       @default(0)
  plan          String    @default("FREE")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relationships
  jobs          Job[]
  applications  Application[]
  resumes       Resume[]
  interviews    Interview[]
}

model Resume {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  name        String
  size        Int
  url         String
  createdAt   DateTime  @default(now())
}

model Job {
  id              String    @id @default(uuid())
  title           String
  description     String
  company         String
  location        String
  locationType    String    // remote, hybrid, in-office
  jobType         String    // full-time, part-time, contract, etc.
  experienceLevel String    // junior, mid, senior
  salary          String?
  logoUrl         String?
  isActive        Boolean   @default(true)
  isFeatured      Boolean   @default(false)
  viewsCount      Int       @default(0)
  likesCount      Int       @default(0)
  postedAt        DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relationships
  employer        User      @relation(fields: [employerId], references: [id])
  employerId      String
  applications    Application[]
}

model Application {
  id              String    @id @default(uuid())
  stage           String    @default("Applied") // Applied, Screening, Interview, Offered, Rejected
  rating          Int       @default(0)
  resumeUrl       String?
  resumeText      String?
  appliedAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relationships
  candidate       User      @relation(fields: [candidateId], references: [id])
  candidateId     String
  job             Job       @relation(fields: [jobId], references: [id])
  jobId           String
}

model Subscription {
  id               String    @id @default(uuid())
  clerkId          String    @unique
  stripeCustomerId String?   @unique
  stripePriceId    String?
  status           String?   // active, canceled, trialing, etc.
  plan             String?   // basic, growth, enterprise
  updatedAt        DateTime  @updatedAt
}

model Interview {
  id            String    @id @default(uuid())
  candidateName String
  candidateEmail String?
  role          String?
  date          String
  time          String
  type          String    // Online, Ofisdə, Telefon
  status        String    @default("Upcoming") // Upcoming, Completed, Cancelled
  location      String?
  link          String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relationships
  employer      User      @relation(fields: [employerId], references: [id])
  employerId    String
}
